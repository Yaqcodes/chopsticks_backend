# =============================================================================
# CHOPSTICKS BACKEND - RAILWAY ENVIRONMENT
# =============================================================================
# Copy real values into the Railway service "Variables" tab. DO NOT commit secrets.
# Anything left blank or commented out keeps the existing safe default in settings.
#
# Reference: chopsticks_backend/RAILWAY.md
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO CORE
# -----------------------------------------------------------------------------

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_STRONG_UNIQUE_SECRET_KEY

# Must be False in production.
DEBUG=False

# Public base URL of THIS backend. Until a custom domain is set up, use the
# Railway-provided URL (e.g. https://my-service.up.railway.app). All OAuth
# callbacks, Paystack callbacks, and absolute media URLs derive from this.
BASE_URL=https://REPLACE_WITH_RAILWAY_PUBLIC_URL

# Comma-separated. Include the API host(s) the world will reach the service at.
# Examples: my-service.up.railway.app, api.zmall.ng
ALLOWED_HOSTS=REPLACE_WITH_API_HOST,localhost,127.0.0.1

# Comma-separated, scheme-included. Storefront origins that may call this API.
CORS_ALLOWED_ORIGINS=https://zmall.ng,https://www.zmall.ng,https://chopsticksandbowls.com,https://www.chopsticksandbowls.com,https://roschiwater.com,https://www.roschiwater.com

# Comma-separated, scheme-included. Required for Django admin POSTs behind a
# TLS-terminating proxy. BASE_URL is added automatically by settings; list any
# extra origins (e.g. tenant frontends that POST forms) here.
CSRF_TRUSTED_ORIGINS=

# OAuth callback host (defaults to BASE_URL when unset).
# OAUTH_BASE_URL=

# -----------------------------------------------------------------------------
# DATABASE - Railway Postgres
# -----------------------------------------------------------------------------

# Connect the Railway Postgres service to this Django service via Variable References.
# Railway exposes DATABASE_URL automatically when the services are linked.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# -----------------------------------------------------------------------------
# OBJECT STORAGE - Railway Bucket (S3-compatible, private)
# -----------------------------------------------------------------------------
# Use Railway's "Connect Service to Bucket" so these are injected automatically:
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
ENDPOINT=https://storage.railway.app
REGION=auto

# Phase 1 (default): presigned GET URLs against the private bucket. TTL is in seconds.
# AWS_QUERYSTRING_AUTH=True
# AWS_QUERYSTRING_EXPIRE=604800

# Phase 2 (later, when a CDN sits in front of the bucket): set this to the public
# CDN base URL and storage URLs become stable, cacheable, unsigned.
# MEDIA_CDN_BASE_URL=https://cdn.zmall.ng

# -----------------------------------------------------------------------------
# PAYSTACK
# -----------------------------------------------------------------------------

# Per-business keys live on RestaurantSettings; these are optional fallbacks.
PAYSTACK_SECRET_KEY_TEST=
PAYSTACK_PUBLIC_KEY_TEST=
PAYSTACK_BASE_URL=https://api.paystack.co

# -----------------------------------------------------------------------------
# EMAIL (use real SMTP in production)
# -----------------------------------------------------------------------------

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=REPLACE_WITH_SMTP_USER
EMAIL_HOST_PASSWORD=REPLACE_WITH_SMTP_APP_PASSWORD
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# GOOGLE / SOCIAL AUTH
# -----------------------------------------------------------------------------

GOOGLE_MAPS_API_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=
SOCIAL_AUTH_APPLE_ID_CLIENT=
SOCIAL_AUTH_APPLE_ID_TEAM=
SOCIAL_AUTH_APPLE_ID_KEY=

# -----------------------------------------------------------------------------
# LOYALTY / ORDER DEFAULTS (override per env if needed)
# -----------------------------------------------------------------------------

POINTS_PER_DOLLAR=1
BIRTHDAY_BONUS_POINTS=5000
FIRST_ORDER_BONUS_POINTS=1000
REFERRAL_BONUS_POINTS=1000

PHYSICAL_VISIT_POINTS=500
LUNCH_VISIT_BONUS=25
DINNER_VISIT_BONUS=25
HAPPY_HOUR_BONUS=30
MIN_SCAN_INTERVAL_MINUTES=30

BRONZE_TIER_POINTS=0
SILVER_TIER_POINTS=50000
GOLD_TIER_POINTS=100000
PLATINUM_TIER_POINTS=250000

DELIVERY_FEE_BASE=2000.00
DELIVERY_FEE_PER_KM=150.00
TAX_RATE=0.075

# =============================================================================
# CHOPSTICKS BACKEND - PRODUCTION ENVIRONMENT
# =============================================================================
# Copy to .env on the server or set in your host's env vars (e.g. Railway Variables).
# DO NOT commit .env or real secrets to version control.
#
# Railway deploy: see RAILWAY.md and .env.railway.template (same variables).
# Legacy PythonAnywhere: see PYTHONANYWHERE.md (local /media/ + static mappings).
#
# Local dev: leave DATABASE_URL and BUCKET unset → SQLite + disk under media/.
# =============================================================================

# =============================================================================
# DJANGO CORE SETTINGS
# =============================================================================

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_STRONG_UNIQUE_SECRET_KEY

# MUST be False in production
DEBUG=False

# Public base URL of THIS backend (scheme required). Drives OAuth, Paystack callbacks,
# and absolute media URLs when not using a CDN. After first Railway deploy, set this to
# your *.up.railway.app URL; later switch to a custom domain (e.g. https://api.zmall.ng)
# without code changes—only update this and third-party dashboards.
BASE_URL=https://REPLACE_WITH_API_PUBLIC_URL

# Comma-separated hostnames (no scheme). Include Railway host, custom API domain, etc.
ALLOWED_HOSTS=REPLACE_WITH_API_HOST,localhost,127.0.0.1,chopsticks-frontend.vercel.app,chopsticksandbowls.com,www.chopsticksandbowls.com,roschiwater.com,www.roschiwater.com,zmall.ng,www.zmall.ng

# Comma-separated origins with scheme. Storefronts that call this API.
CORS_ALLOWED_ORIGINS=https://chopsticks-frontend.vercel.app,https://chopsticksandbowls.com,https://www.chopsticksandbowls.com,https://roschiwater.com,https://www.roschiwater.com,https://zmall.ng,https://www.zmall.ng

# Comma-separated origins with scheme. Required for Django admin POSTs behind TLS proxy
# (Railway). BASE_URL is appended automatically in settings; add extras if needed.
CSRF_TRUSTED_ORIGINS=

# OAuth callback host (defaults to BASE_URL when unset)
# OAUTH_BASE_URL=

# FRONTEND_BASE_URL is not used — tenant frontends come from RestaurantSettings.domain

# =============================================================================
# DATABASE
# =============================================================================

# Production (Railway Postgres): set when linking the Postgres plugin. Parsed via dj-database-url.
# Omit entirely for local dev (falls back to db.sqlite3).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Legacy per-field Postgres (NOT used by settings — prefer DATABASE_URL above):
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_HOST=
# DATABASE_PORT=5432

# =============================================================================
# OBJECT STORAGE (Railway Bucket — S3-compatible, private)
# =============================================================================
# Link the bucket to the Django service on Railway to inject these automatically.
# Omit all bucket vars for local dev (FileSystemStorage under media/).

BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
ENDPOINT=https://storage.railway.app
REGION=auto

# Phase 1 (default): presigned GET URLs; TTL in seconds (default 7 days in settings).
# AWS_QUERYSTRING_AUTH=True
# AWS_QUERYSTRING_EXPIRE=604800

# Phase 2: when a CDN fronts the bucket, set stable public base and disable presigning:
# MEDIA_CDN_BASE_URL=https://cdn.zmall.ng
# AWS_QUERYSTRING_AUTH=False

# Optional: path-style vs virtual-hosted (Railway default: virtual)
# AWS_S3_ADDRESSING_STYLE=virtual

# =============================================================================
# PAYSTACK PAYMENT CONFIGURATION
# =============================================================================

# Per-business keys are stored in RestaurantSettings. These are optional fallbacks.
PAYSTACK_SECRET_KEY_TEST=
PAYSTACK_PUBLIC_KEY_TEST=
# PAYSTACK_SECRET_KEY_LIVE=sk_live_your_live_secret_key_here
# PAYSTACK_PUBLIC_KEY_LIVE=pk_live_your_live_public_key_here

PAYSTACK_BASE_URL=https://api.paystack.co

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=REPLACE_WITH_SMTP_USER
EMAIL_HOST_PASSWORD=REPLACE_WITH_SMTP_APP_PASSWORD
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# GOOGLE SERVICES
# =============================================================================

GOOGLE_MAPS_API_KEY=REPLACE_IF_USING_MAPS_OR_GEOCODING

# =============================================================================
# SOCIAL AUTHENTICATION (OAuth)
# =============================================================================

# Redirect URIs must include: {BASE_URL}/accounts/google/login/callback/ (per provider docs)
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=REPLACE_WITH_PRODUCTION_GOOGLE_OAUTH2_KEY
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=REPLACE_WITH_PRODUCTION_GOOGLE_OAUTH2_SECRET

SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=

SOCIAL_AUTH_APPLE_ID_CLIENT=
SOCIAL_AUTH_APPLE_ID_TEAM=
SOCIAL_AUTH_APPLE_ID_KEY=

# =============================================================================
# RESTAURANT / BUSINESS DEFAULTS (overridden per tenant in RestaurantSettings)
# =============================================================================

RESTAURANT_NAME=Production
RESTAURANT_ADDRESS=Your Business Address
RESTAURANT_PHONE=+234XXXXXXXXXX
RESTAURANT_EMAIL=info@yourdomain.com

# =============================================================================
# LOYALTY SYSTEM SETTINGS
# =============================================================================

POINTS_PER_DOLLAR=1
BIRTHDAY_BONUS_POINTS=5000
FIRST_ORDER_BONUS_POINTS=1000
REFERRAL_BONUS_POINTS=1000

PHYSICAL_VISIT_POINTS=500
LUNCH_VISIT_BONUS=25
DINNER_VISIT_BONUS=25
HAPPY_HOUR_BONUS=30
MIN_SCAN_INTERVAL_MINUTES=30

BRONZE_TIER_POINTS=0
SILVER_TIER_POINTS=50000
GOLD_TIER_POINTS=100000
PLATINUM_TIER_POINTS=250000

# =============================================================================
# ORDER & DELIVERY DEFAULTS (overridden per business in RestaurantSettings)
# =============================================================================

MINIMUM_ORDER_AMOUNT=1000.00
DELIVERY_FEE_BASE=2000.00
DELIVERY_FEE_PER_KM=150.00
TAX_RATE=0.075

# =============================================================================
# PRODUCTION CHECKLIST (Railway)
# =============================================================================
# 1. Set SECRET_KEY to a new random value; keep DEBUG=False.
# 2. Set BASE_URL to the public API URL after deploy; update ALLOWED_HOSTS to match.
# 3. Link Postgres → DATABASE_URL; link Bucket → BUCKET, ACCESS_KEY_ID, SECRET_ACCESS_KEY, ENDPOINT, REGION.
# 4. Deploy runs migrate + collectstatic (Procfile release); healthcheck: /healthz/
# 5. Register OAuth redirect URIs and Paystack callback against BASE_URL.
# 6. Migrate data: Postgres dump/load + sync legacy media/ to bucket (preserve keys).
# 7. Ensure each tenant has RestaurantSettings with correct domain and Paystack keys.
#
# Legacy PythonAnywhere only: map /static/ and /media/ in the Web tab; see PYTHONANYWHERE.md.
# =============================================================================

# =============================================================================
# CHOPSTICKS BACKEND - PRODUCTION ENVIRONMENT (e.g. PythonAnywhere)
# =============================================================================
# Copy to .env on the production server or set in the host's env vars.
# Replace YOUR_PA_USERNAME with your PythonAnywhere username.
# DO NOT commit .env or real secrets to version control.
# =============================================================================

# =============================================================================
# DJANGO CORE SETTINGS
# =============================================================================

# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_STRONG_UNIQUE_SECRET_KEY

# MUST be False in production
DEBUG=False

# PA host + all tenant domains that hit this backend
ALLOWED_HOSTS=YOUR_PA_USERNAME.pythonanywhere.com,localhost,127.0.0.1,chopsticks-frontend.vercel.app,chopsticksandbowls.com,www.chopsticksandbowls.com,roschiwater.com,www.roschiwater.com,zmall.ng,www.zmall.ng

# Backend base URL (no trailing slash)
BASE_URL=https://YOUR_PA_USERNAME.pythonanywhere.com

# Not used for routing; per-tenant domains come from RestaurantSettings
# FRONTEND_BASE_URL=https://zmall.ng

# =============================================================================
# CORS
# =============================================================================

# All frontend origins that will call this API
CORS_ALLOWED_ORIGINS=https://chopsticks-frontend.vercel.app,https://chopsticksandbowls.com,https://www.chopsticksandbowls.com,https://roschiwater.com,https://www.roschiwater.com,https://zmall.ng,https://www.zmall.ng

# =============================================================================
# DATABASE
# =============================================================================

# SQLite on PythonAnywhere: no vars needed (uses db.sqlite3 in project dir).
# For PostgreSQL, configure in settings or via DATABASE_* if supported.
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=your_database_name
# DATABASE_USER=your_database_user
# DATABASE_PASSWORD=your_database_password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# =============================================================================
# PAYSTACK
# =============================================================================

# Per-business keys go in RestaurantSettings. These are optional fallbacks. Use live keys in production.
PAYSTACK_SECRET_KEY_TEST=
PAYSTACK_PUBLIC_KEY_TEST=
# PAYSTACK_SECRET_KEY_LIVE=sk_live_your_live_secret_key_here
# PAYSTACK_PUBLIC_KEY_LIVE=pk_live_your_live_public_key_here

PAYSTACK_BASE_URL=https://api.paystack.co

# =============================================================================
# EMAIL (use real SMTP in production)
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=REPLACE_WITH_SMTP_USER
EMAIL_HOST_PASSWORD=REPLACE_WITH_SMTP_APP_PASSWORD
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# GOOGLE
# =============================================================================

GOOGLE_MAPS_API_KEY=REPLACE_IF_USING_MAPS_OR_GEOCODING

# =============================================================================
# SOCIAL AUTHENTICATION (OAuth)
# =============================================================================

# Must match BASE_URL. Redirect URIs must include: https://YOUR_PA_USERNAME.pythonanywhere.com/accounts/google/login/callback/
OAUTH_BASE_URL=https://YOUR_PA_USERNAME.pythonanywhere.com

SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=REPLACE_WITH_PRODUCTION_GOOGLE_OAUTH2_KEY
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=REPLACE_WITH_PRODUCTION_GOOGLE_OAUTH2_SECRET

SOCIAL_AUTH_FACEBOOK_KEY=
SOCIAL_AUTH_FACEBOOK_SECRET=

SOCIAL_AUTH_APPLE_ID_CLIENT=
SOCIAL_AUTH_APPLE_ID_TEAM=
SOCIAL_AUTH_APPLE_ID_KEY=

# =============================================================================
# RESTAURANT DEFAULTS (overridden per tenant in RestaurantSettings)
# =============================================================================

RESTAURANT_NAME=Production
RESTAURANT_ADDRESS=Your Business Address
RESTAURANT_PHONE=+234XXXXXXXXXX
RESTAURANT_EMAIL=info@yourdomain.com

# =============================================================================
# LOYALTY
# =============================================================================

POINTS_PER_DOLLAR=1
BIRTHDAY_BONUS_POINTS=5000
FIRST_ORDER_BONUS_POINTS=1000
REFERRAL_BONUS_POINTS=1000

PHYSICAL_VISIT_POINTS=500
LUNCH_VISIT_BONUS=25
DINNER_VISIT_BONUS=25
HAPPY_HOUR_BONUS=30
MIN_SCAN_INTERVAL_MINUTES=30

BRONZE_TIER_POINTS=0
SILVER_TIER_POINTS=50000
GOLD_TIER_POINTS=100000
PLATINUM_TIER_POINTS=250000

# =============================================================================
# ORDER & DELIVERY
# =============================================================================

MINIMUM_ORDER_AMOUNT=1000.00
DELIVERY_FEE_BASE=2000.00
DELIVERY_FEE_PER_KM=150.00
TAX_RATE=0.075

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# 1. Set SECRET_KEY to a new random value.
# 2. Keep DEBUG=False.
# 3. In PythonAnywhere Web tab, add Static files mappings:
#    /static/  -> /home/YOUR_PA_USERNAME/chopsticks_backend/staticfiles
#    /media/   -> /home/YOUR_PA_USERNAME/chopsticks_backend/media
# 4. Run: python manage.py collectstatic --noinput
# 5. Ensure each tenant has RestaurantSettings with correct domain and Paystack keys.
# =============================================================================
